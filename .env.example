# ══════════════════════════════════════════════════════
#  THE WELFARE SHOP — Environment Variables
#  Copier ce fichier en .env.local (jamais committer)
# ══════════════════════════════════════════════════════

# ─── PostgreSQL ────────────────────────────────────────
POSTGRES_PASSWORD=welfare_dev_secret
DATABASE_URL=postgresql://welfare:welfare_dev_secret@localhost:5432/welfare_db

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Meilisearch ───────────────────────────────────────
MEILI_MASTER_KEY=welfare_meili_dev_key
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=welfare_meili_dev_key

# ─── Medusa ────────────────────────────────────────────
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_BACKEND_URL=http://localhost:9000
JWT_SECRET=welfare_jwt_super_secret_change_in_prod
COOKIE_SECRET=welfare_cookie_super_secret_change_in_prod

# ─── Supabase (Auth + Storage) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── AI (My Skin Coach) ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
# ou OpenAI:
# OPENAI_API_KEY=your_openai_api_key
AI_SERVICE_URL=http://localhost:4000

# ─── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@thewelfareshop.cm

# ─── Analytics (PostHog) ───────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App URLs ──────────────────────────────────────────
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:9000

# ─── Paiement (Phase 1 : Manuel) ───────────────────────
PAYMENT_PROVIDER=manual
# Phase 2 (Tchedes) :
# PAYMENT_PROVIDER=tchedes
# TCHEDES_API_KEY=your_tchedes_api_key
# TCHEDES_SECRET=your_tchedes_secret
# TCHEDES_WEBHOOK_SECRET=your_tchedes_webhook_secret
